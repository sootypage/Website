<%- include('partials/head') %>
<%- include('partials/nav') %>
<%- include('partials/flash') %>
<section class="auth-box card">
  <h1>Sign up</h1>
  <p class="muted">This password is used for the website and can be sent to your panel provisioning API for the same panel login.</p>
  <form method="post" action="/auth/signup" class="form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>Username<input name="username" required></label>
    <label>Email<input name="email" type="email" required></label>
    <label>Password<input name="password" type="password" minlength="8" required></label>
    <button class="btn full">Create account</button>
  </form>
</section>
<%- include('partials/footer') %>
