<%- include('partials/head') %>
<%- include('partials/nav') %>
<%- include('partials/flash') %>
<section class="section narrow">
  <h1>Checkout</h1>
  <div class="card">
    <h2><%= plan.name %></h2>
    <p><%= plan.description %></p>
    <p class="muted">Buying as <strong><%= currentUser.username %></strong> · <%= currentUser.email %></p>

    <form method="post" action="/shop/checkout/<%= plan.id %>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">" class="form">
      <h3>Base plan</h3>
      <div class="summary">
        <span><%= plan.ramGb %>GB RAM</span>
        <span><%= plan.cpuCores %> CPU</span>
        <span><%= plan.storageGb %>GB storage</span>
        <span><%= plan.backupSlots %> backup slots</span>
        <span><%= plan.subdomainSlots %> subdomains</span>
        <span><%= plan.extraPorts %> ports</span>
      </div>

      <h3>Add upgrades</h3>
      <div class="upgrade-list">
        <% upgrades.forEach(up => { %>
          <label class="upgrade">
            <input type="checkbox" name="upgrades" value="<%= up.id %>">
            <span><strong><%= up.name %></strong><small>+$<%= up.priceMonthly %>/mo</small></span>
          </label>
        <% }) %>
      </div>

      <button class="btn full">Pay / Create order</button>
    </form>
  </div>
</section>
<%- include('partials/footer') %>
