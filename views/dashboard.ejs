<%- include('partials/head') %>
<%- include('partials/nav') %>
<%- include('partials/flash') %>
<section class="section">
  <h1>📊 Dashboard</h1>
  <p class="muted">Welcome back, <%= currentUser.username %>.</p>

  <div class="grid cards">
    <div class="card stat"><span><%= orders.length %></span><p>🛒 Orders</p></div>
    <div class="card stat"><span><%= tickets.length %></span><p>🎫 Support tickets</p></div>
    <div class="card stat"><span><%= currentUser.role %></span><p>👤 Role</p></div>
  </div>

  <div class="section-head"><h2>🖥️ Your servers/orders</h2><a class="btn small" href="/shop">🛒 Buy another</a></div>
  <div class="table-card">
    <table>
      <thead><tr><th>Server</th><th>Plan</th><th>Status</th><th>Panel</th><th>Price</th></tr></thead>
      <tbody>
      <% orders.forEach(order => { %>
        <tr>
          <td>
            <strong><%= order.serverConfig?.serverName || 'Unnamed' %></strong><br>
            <small class="muted"><%= order.serverConfig?.variantName || order.plan.type %></small><br>
            <small class="muted">🌍 <%= order.serverConfig?.locationName || 'Unknown' %></small>
          </td>
          <td><%= order.plan.name %></td>
          <td><span class="pill"><%= order.status %></span></td>
          <td><%= order.panelProvisionStatus %></td>
          <td>$<%= order.totalMonthly %>/mo</td>
        </tr>
      <% }) %>
      <% if (!orders.length) { %><tr><td colspan="5">No orders yet.</td></tr><% } %>
      </tbody>
    </table>
  </div>

  <div class="section-head"><h2>🎫 Your support tickets</h2><a class="btn small ghost" href="/support">✉️ Open ticket</a></div>
  <div class="grid cards">
    <% tickets.forEach(ticket => { %>
      <div class="card">
        <span class="pill"><%= ticket.status %></span>
        <h3><%= ticket.subject %></h3>
        <p><%= ticket.message %></p>
        <% if (ticket.adminReply) { %><p class="reply"><strong>Admin:</strong> <%= ticket.adminReply %></p><% } %>
      </div>
    <% }) %>
  </div>
</section>
<%- include('partials/footer') %>
