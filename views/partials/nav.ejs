<nav class="nav">
  <a class="brand" href="/"><%= siteName %></a>
  <button class="mobile-menu-toggle" aria-label="Toggle menu">☰</button>
  <div class="nav-links">
    <a href="/shop">Shop</a>
    <a href="/reviews">Reviews</a>
    <% if (currentUser) { %>
      <a href="/dashboard">Dashboard</a>
      <a href="/support">Support</a>
      <% if (currentUser.role === 'admin') { %><a href="/admin">Admin</a><% } %>
      <form action="/auth/logout" method="post" class="inline">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="link-btn">Logout</button></form>
    <% } else { %>
      <a href="/auth/login">Login</a>
      <a class="btn small" href="/auth/signup">Sign up</a>
    <% } %>
  </div>
</nav>
